{
  "scripts": {
    "css:init": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css",
    "css:dev": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch",
    "css:build": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --minify",
    "postinstall": "npm run css:init"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14"
  }
}
